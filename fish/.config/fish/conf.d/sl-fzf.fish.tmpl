# fzf — token-driven base (from [semantic]) + the focused workspace's identity hue.
# $SL_IDENTITY is set by scene.sh when a workspace's terminal is spawned; absent (a
# hand-opened terminal) it falls back to the global accent. So fzf in the coding
# workspace highlights blue, in engine coral — the stack breathes the identity.
# GENERATED by render-templates from system/tokens.toml — edit the .tmpl, not this.
set -l _accent "$SL_IDENTITY"
test -z "$_accent"; and set _accent "{{color.primary}}"
set -l _o "--height=40% --layout=reverse --border=rounded --info=inline"
set _o "$_o --pointer={{powerline.round_right}} --marker={{powerline.round_left}} --prompt='{{powerline.round_right}} ' --preview-window=border-rounded"
set _o "$_o --color=bg+:{{semantic.bg_tertiary}},fg:{{semantic.text_secondary}},fg+:{{semantic.text_primary}}"
set _o "$_o --color=hl:$_accent,hl+:$_accent,marker:$_accent,pointer:$_accent,spinner:$_accent"
set _o "$_o --color=prompt:{{semantic.text_tertiary}},border:{{semantic.border_tertiary}},info:{{semantic.text_tertiary}}"
set -gx FZF_DEFAULT_OPTS "$_o"
