# SlicedLabs — gh-dash theme + sections (Track 9.1). GENERATED from system/tokens.toml
# by render-templates — edit the .tmpl, not this. Chrome rides identity/[semantic].
prSections:
  - title: My Pull Requests
    filters: is:open author:@me
  - title: Needs My Review
    filters: is:open review-requested:@me
  - title: Involved
    filters: is:open involves:@me -author:@me
issuesSections:
  - title: My Issues
    filters: is:open author:@me
  - title: Assigned
    filters: is:open assignee:@me
defaults:
  preview:
    open: true
    width: 60
  prsLimit: 20
  issuesLimit: 20
theme:
  ui:
    sectionsShowCount: true
    table:
      showSeparator: true
      compact: false
  colors:
    text:
      primary: "{{semantic.text_primary}}"
      secondary: "{{semantic.text_secondary}}"
      inverted: "{{color.bg}}"
      faint: "{{semantic.text_tertiary}}"
      warning: "{{color.error}}"
      success: "{{color.success}}"
    background:
      selected: "{{color.selection}}"
    border:
      primary: "{{color.primary}}"
      secondary: "{{semantic.border_tertiary}}"
      faint: "{{semantic.border_tertiary}}"
