# SlicedLabs — btop theme. GENERATED by render-templates from system/tokens.toml.
# Graphs ride the cool→warm signal ramp; boxes are hairline; chrome on the palette.
theme[main_bg]="{{color.bg}}"
theme[main_fg]="{{color.fg}}"
theme[title]="{{color.fg}}"
theme[hi_fg]="{{color.primary}}"
theme[selected_bg]="{{color.selection}}"
theme[selected_fg]="{{color.fg}}"
theme[inactive_fg]="{{color.inactive}}"
theme[graph_text]="{{color.fg_muted}}"
theme[meter_bg]="{{color.bg_alt}}"
theme[proc_misc]="{{color.mist}}"
theme[cpu_box]="{{color.inactive}}"
theme[mem_box]="{{color.inactive}}"
theme[net_box]="{{color.inactive}}"
theme[proc_box]="{{color.inactive}}"
theme[div_line]="{{color.inactive}}"
# CPU load: green → honey → coral
theme[cpu_start]="{{color.success}}"
theme[cpu_mid]="{{color.honey}}"
theme[cpu_end]="{{color.error}}"
# Temperature: cool sky → honey → coral
theme[temp_start]="{{color.secondary}}"
theme[temp_mid]="{{color.honey}}"
theme[temp_end]="{{color.error}}"
# Memory used: green → honey → coral
theme[used_start]="{{color.success}}"
theme[used_mid]="{{color.honey}}"
theme[used_end]="{{color.error}}"
theme[free_start]="{{color.success}}"
theme[free_mid]="{{color.success}}"
theme[free_end]="{{color.mist}}"
theme[cached_start]="{{color.sand}}"
theme[cached_mid]="{{color.honey}}"
theme[cached_end]="{{color.honey}}"
theme[available_start]="{{color.mist}}"
theme[available_mid]="{{color.secondary}}"
theme[available_end]="{{color.secondary}}"
# Network: download cool, upload warm
theme[download_start]="{{color.secondary}}"
theme[download_mid]="{{color.mist}}"
theme[download_end]="{{color.secondary}}"
theme[upload_start]="{{color.tertiary}}"
theme[upload_mid]="{{color.honey}}"
theme[upload_end]="{{color.tertiary}}"
