// [ENGINE] COMMAND CENTER (zj engine-dev) — the dense cockpit deck, Rust‑flavored.
// Mirrors `coding` (~/Downloads/0.png) but pointed at ~/SlicedLabs/tools/engine by the
// `engine` scene, in the engine‑coral hue:
//
//   ┌ Neovim (dominant) ─────────┬ rail ┬ Sli labs ┬ Claude ┐
//   │                            │ Tree │ (susp)   │ (susp) │
//   │                            │ Git  │          │        │
//   │                            │ Bacon│ (susp)   │        │
//   ├ Debugger console ┬ Logger ─┴──────┴──────────┴────────┤
//   │                  │ console                            │
//   └──────────────────┴────────────────────────────────────┘
//
// Tile 3 is `bacon` (continuous cargo check/test = live Rust diagnostics) — CPU‑heavy,
// so start_suspended like the AI pair (0 cost until Enter). The wgpu/Rust docs Firefox,
// the VM Stack, and the CI/GitHub columns are SEPARATE niri columns (engine‑web /
// engine‑vm / engine‑ci) that niri scrolls to. Zen: Ctrl+p f. Scratch float: Alt+f.
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zjstatus" {
                format_left   " {tabs}"
                format_center ""
                format_right  "{mode}#[bg={{color.bg}}]  #[fg=#{{color_raw.engine}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg=#{{color_raw.engine}},bold] {{icon.clock}} {datetime} #[fg=#{{color_raw.engine}},bg={{color.bg}}]{{powerline.round_right}} "
                format_space  "#[bg={{color.bg}}]"
                format_precedence "lrc"
                border_enabled "false"

                tab_normal    "#[fg={{semantic.bg_tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{semantic.text_secondary}},bg={{semantic.bg_tertiary}}] {name} #[fg={{semantic.bg_tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                tab_active    "#[fg=#{{color_raw.engine}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg=#{{color_raw.engine}},bold] {{powerline.dot}} {name} #[fg=#{{color_raw.engine}},bg={{color.bg}}]{{powerline.round_right}}"
                tab_separator "#[bg={{color.bg}}] "

                mode_normal       "#[fg={{color.success}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.success}},bold] NORMAL #[fg={{color.success}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_locked       "#[fg={{semantic.text_tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{semantic.text_tertiary}},bold] LOCKED #[fg={{semantic.text_tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_pane         "#[fg=#{{color_raw.engine}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg=#{{color_raw.engine}},bold] PANE #[fg=#{{color_raw.engine}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_tab          "#[fg=#{{color_raw.engine}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg=#{{color_raw.engine}},bold] TAB #[fg=#{{color_raw.engine}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_resize       "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] RESIZE #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_move         "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] MOVE #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_scroll       "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] SCROLL #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_search       "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] SEARCH #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_enter_search "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] SEARCH #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_rename_tab   "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] RENAME #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_rename_pane  "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] RENAME #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_session      "#[fg={{color.wisteria}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.wisteria}},bold] SESSION #[fg={{color.wisteria}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_tmux         "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] TMUX #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_default_to_mode "normal"

                datetime          "{format}"
                datetime_format   "%H:%M"
                datetime_timezone "America/Los_Angeles"
            }
        }
        children
    }

    // deck — the command center. Outer = 3 columns (left block · Sli labs · Claude);
    // the left block stacks editor+rail over the two consoles. bacon + AI suspended.
    tab name="deck" focus=true {
        // EDITOR ROW (top) over a calm full-width CONSOLE strip. Proportions from tokens [layout]
        // — Neovim dominant + slim rail/AI. bacon + AI suspended (0 cost until Enter).
        pane split_direction="horizontal" {
            pane size="{{layout.deck_top}}%" split_direction="vertical" {
                pane size="{{layout.editor_major}}%" command="nvim" { name "Neovim"; }
                pane size="{{layout.rail}}%" split_direction="horizontal" {
                    pane name="Tree" command="fish" {
                        args "-C" "eza --tree --level=2 --icons --git 2>/dev/null"
                    }
                    pane name="Git" command="fish" {
                        args "-C" "git -c color.ui=always status -sb 2>/dev/null; and git -c color.ui=always log --oneline -8 2>/dev/null"
                    }
                    pane name="Bacon" command="bacon" {
                        start_suspended true   // continuous cargo check/test — CPU-heavy → 0 until Enter
                    }
                }
                pane size="{{layout.aux_slim}}%" command="slicedlabs" {
                    start_suspended true
                    name "AI · Sli labs"
                }
                pane command="slc-claude" {
                    start_suspended true
                    name "AI · Claude"
                }
            }
            pane size="{{layout.console_h}}%" split_direction="vertical" {
                pane name="Debugger console" command="sl-debug"   // detects Cargo.toml → rust-lldb / lldb-dap
                pane name="Logger console" command="sl-log"       // live engine logs → lnav (engine_log format)
            }
        }
    }

    // Classic tabs RESTORED (their original functionality) — selectable pills beside `deck`.
    tab name="code" {
        pane command="nvim" { name "Neovim"; }
    }
    tab name="build" {
        pane split_direction="vertical" {
            pane command="bacon" { start_suspended true; name "bacon"; }
            pane name="cargo run · test" command="sl-run"
        }
    }
    tab name="git" {
        pane split_direction="vertical" {
            pane command="lazygit" { start_suspended true; name "lazygit"; }
            pane command="gh-dash" { start_suspended true; name "gh-dash"; }
        }
    }
    tab name="debug" {
        pane split_direction="vertical" {
            pane name="rust-gdb · lldb" command="sl-debug" { start_suspended true; }
            pane name="RUST_LOG · journalctl" command="sl-log" { start_suspended true; }
        }
    }
    // ── IDE pillars (engine is a Rust project — inherits the coding ring) ──
    tab name="problems" {
        pane name="diagnostics" command="sl-diag" { args "--clippy"; start_suspended true; }
    }
    tab name="test" {
        pane name="tests" command="sl-test" { args "list"; start_suspended true; }
    }
    tab name="search" {
        pane name="find" command="sl-find" { args "-i"; start_suspended true; }
    }
    // ── engine render-dev (the specialized surfaces) ──
    tab name="run" {
        pane name="live engine" command="sl-engine" { args "run"; start_suspended true; }
    }
    tab name="shaders" {
        pane split_direction="vertical" {
            pane size="{{layout.phi_major}}%" command="nvim" { name "slang"; }
            pane size="{{layout.phi_minor}}%" name="slangc → spirv-dis" command="sl-shader" { start_suspended true; }
        }
    }
    tab name="gpu" {
        pane name="RenderDoc" command="qrenderdoc" { start_suspended true; }
    }
    tab name="oracles" {
        pane name="determinism · golden suite" command="sl-engine" { args "oracles"; start_suspended true; }
    }
    tab name="profile" {
        pane name="profiler" command="sl-profile" { start_suspended true; }
    }
    tab name="data" {
        pane split_direction="vertical" {
            pane command="dbshell" { start_suspended true; name "dbshell"; }
            pane command="sqlite3" { start_suspended true; name "sqlite3"; }
        }
    }
    // ssh — the MacBook Air LAN build/test/sign node (Host `mac`). RESTORED.
    tab name="ssh" {
        pane command="ssh" { args "mac"; name "mac · MacBook Air"; }
    }
    // term — a plain working terminal on the main-screen cockpit.
    tab name="term" {
        pane name="terminal"
    }
}
