// [ENGINE] research dev-cockpit (zj research) — a full-scope environment for deep
// thinking, auditing, architecture, and design-systems work. Launched by the `research`
// scene (ghostty -e zj research, cwd ~/Documents/research); a dedicated Firefox rides
// alongside as the scene's second niri column. zjstatus pill bar from system/tokens.toml.
//
// Tabs:
//   study      — VIM notepad (NOTES.md) │ books (TUI corpus reader) + shell
//   architect  — Claude Code │ slicedlabs (in-house AI team) — architecture & ADRs
//   design     — nvim system/tokens.toml │ shell (~/.dotfiles: render-templates · chafa preview)
//   audit      — lazygit │ shell (git log · delta · rg · semgrep · ruff)
//   read       — books (TUI corpus reader) │ shell (pandoc · pdftotext · fetch)
//   write      — nvim DRAFT.md │ shell (typst watch · glow preview)
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zjstatus" {
                format_left   " {tabs}"
                format_center ""
                format_right  "{mode}#[bg={{color.bg}}]  #[fg=#{{color_raw.research}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg=#{{color_raw.research}},bold] {{icon.clock}} {datetime} #[fg=#{{color_raw.research}},bg={{color.bg}}]{{powerline.round_right}} "
                format_space  "#[bg={{color.bg}}]"
                format_precedence "lrc"
                border_enabled "false"

                tab_normal    "#[fg={{semantic.bg_tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{semantic.text_secondary}},bg={{semantic.bg_tertiary}}] {index} {name} #[fg={{semantic.bg_tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                tab_active    "#[fg=#{{color_raw.research}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg=#{{color_raw.research}},bold] {{powerline.dot}} {index} {name} #[fg=#{{color_raw.research}},bg={{color.bg}}]{{powerline.round_right}}"
                tab_separator "#[bg={{color.bg}}] "

                mode_normal       "#[fg={{color.success}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.success}},bold] NORMAL #[fg={{color.success}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_locked       "#[fg={{semantic.text_tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{semantic.text_tertiary}},bold] LOCKED #[fg={{semantic.text_tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_pane         "#[fg=#{{color_raw.research}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg=#{{color_raw.research}},bold] PANE #[fg=#{{color_raw.research}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_tab          "#[fg=#{{color_raw.research}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg=#{{color_raw.research}},bold] TAB #[fg=#{{color_raw.research}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_resize       "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] RESIZE #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_move         "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] MOVE #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_scroll       "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] SCROLL #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_search       "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] SEARCH #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_enter_search "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] SEARCH #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_rename_tab   "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] RENAME #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_rename_pane  "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] RENAME #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_session      "#[fg={{color.wisteria}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.wisteria}},bold] SESSION #[fg={{color.wisteria}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_tmux         "#[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.tertiary}},bold] TMUX #[fg={{color.tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_default_to_mode "normal"

                datetime          "{format}"
                datetime_format   "%H:%M"
                datetime_timezone "America/Los_Angeles"
            }
        }
        children
    }

    tab name="study" focus=true {
        pane split_direction="vertical" {
            pane size="{{layout.phi_major}}%" command="vim" {
                args "NOTES.md"
            }
            pane size="{{layout.phi_minor}}%" split_direction="horizontal" {
                pane command="books"
                pane command="fish" {
                    args "-C" "eza --tree --level=2 --icons --git 2>/dev/null; or ls; echo '— scratch: rg <q> · glow NOTES.md'"
                }
            }
        }
    }
    tab name="architect" {
        pane split_direction="vertical" {
            pane size="{{layout.phi_major}}%" command="slc-claude" { start_suspended true; }
            pane size="{{layout.phi_minor}}%" command="slicedlabs" { start_suspended true; }
        }
    }
    // synthesize — the deep-reasoning surface (the Gemini Deep-Research pattern, manually driven:
    // reason → build the structured argument → cite). Write SYNTHESIS.md while the agent reasons
    // (extended thinking) and the corpus reader supplies book+chapter+page citations.
    tab name="synthesize" {
        pane split_direction="vertical" {
            pane size="{{layout.phi_major}}%" command="nvim" { args "SYNTHESIS.md"; name "synthesis"; }
            pane size="{{layout.phi_minor}}%" split_direction="horizontal" {
                pane command="slc-claude" { start_suspended true; name "reason"; }
                pane command="books" { start_suspended true; name "cite"; }
            }
        }
    }
    tab name="design" {
        pane split_direction="vertical" {
            pane size="{{layout.phi_major}}%" command="nvim" {
                args "/home/doodlebob/.dotfiles/system/tokens.toml"
            }
            pane size="{{layout.phi_minor}}%" cwd="/home/doodlebob/.dotfiles" command="fish" {
                args "-C" "verify-tokens-drift 2>&1 | tail -8; echo '— render-templates · chafa <img> · verify-design-language'"
            }
        }
    }
    tab name="audit" {
        pane split_direction="vertical" {
            pane command="lazygit" { start_suspended true; }
            pane command="sl-audit"   // git log · delta · rg · semgrep · ruff
        }
    }
    tab name="read" {
        pane split_direction="vertical" {
            pane size="{{layout.phi_major}}%" command="books"                   // TUI corpus reader
            pane size="{{layout.phi_minor}}%" command="fish" {
                args "-C" "eza --icons ~/SlicedLabs/vendor/corpus 2>/dev/null | head -30; or ls ~/SlicedLabs/vendor/corpus; echo '— pandoc <f> -t plain · pdftotext <f> | less'"
            }
        }
    }
    tab name="write" {
        pane split_direction="vertical" {
            pane size="{{layout.phi_major}}%" command="nvim" {
                args "DRAFT.md"
            }
            pane size="{{layout.phi_minor}}%" command="fish" {
                args "-C" "eza -la --icons *.typ *.md DRAFT* 2>/dev/null; or ls; echo '— typst watch DRAFT.typ · glow -p DRAFT.md'"
            }
        }
    }
}
