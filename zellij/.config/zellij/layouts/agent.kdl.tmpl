// agent — the AI team window for the coding & engine command centers
// (com.slicedlabs.coding-side / com.slicedlabs.engine-side). A FULL-height window now (its
// own niri column, not an 18% rail): Claude Code and the slicedlabs in-house AI team side
// by side — two tall panes "next to each other". Both load start_suspended (0 tokens until
// Enter). Launched by the scene as `zj agent`, cwd = the scene's --working-directory
// (~/Projects for coding, ~/Projects/engine for engine). Float a scratch shell with Alt+f.
//
// NEUTRAL accent (semantic.text_tertiary): this one layout serves BOTH the coding-blue and
// engine-coral workspaces, so the pill bar stays identity-agnostic — the niri window border
// and the SL_IDENTITY-tinted tools inside carry the workspace hue.
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zjstatus" {
                format_left   " {mode} {tabs}"
                format_center ""
                format_right  "#[fg={{semantic.text_tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{semantic.text_tertiary}},bold] {{icon.clock}} {datetime} #[fg={{semantic.text_tertiary}},bg={{color.bg}}]{{powerline.round_right}} "
                format_space  "#[bg={{color.bg}}]"
                format_precedence "lrc"
                border_enabled "false"

                tab_normal    "#[fg={{semantic.bg_tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{semantic.text_secondary}},bg={{semantic.bg_tertiary}}] {name} #[fg={{semantic.bg_tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                tab_active    "#[fg={{semantic.text_tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{semantic.text_tertiary}},bold] {{powerline.dot}} {name} #[fg={{semantic.text_tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                tab_separator "#[bg={{color.bg}}] "

                mode_normal   "#[fg={{color.success}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{color.success}},bold] NORMAL #[fg={{color.success}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_locked   "#[fg={{semantic.text_tertiary}},bg={{color.bg}}]{{powerline.round_left}}#[fg={{color.bg}},bg={{semantic.text_tertiary}},bold] LOCKED #[fg={{semantic.text_tertiary}},bg={{color.bg}}]{{powerline.round_right}}"
                mode_default_to_mode "normal"

                datetime          "{format}"
                datetime_format   "%H:%M"
                datetime_timezone "America/Los_Angeles"
            }
        }
        children
    }

    tab name="agent" focus=true {
        pane split_direction="vertical" {
            pane size="50%" command="slc-claude" { start_suspended true; name "claude"; }    // governed primary agent — suspended (0 tokens until Enter)
            pane size="50%" command="slicedlabs" { start_suspended true; name "slicedlabs"; } // in-house AI team — suspended
        }
    }
}
