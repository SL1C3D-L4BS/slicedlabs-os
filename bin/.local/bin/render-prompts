#!/usr/bin/env python3
# SlicedLabs · tools · © 2026 SlicedLabs
"""render-prompts — generate .claude/agents/<name>.md from prompts/roles/<name>.md
and the team manifest.

Source of truth (3 inputs):
  1. ~/.dotfiles/sliced-engine/.config/sliced-engine/team.toml — metadata.
  2. ~/.dotfiles/prompts/roles/<name>.md                       — role body.
  3. ~/.dotfiles/prompts/voice/{brand,personal}.md             — global prefixes.

Output:
  ~/.dotfiles/claude-agents/.claude/agents/<name>.md
  ~/.dotfiles/aider/.config/aider/agents/<name>.yml           (aider preset)

Idempotent: rerunning is a no-op if no input changed (compares file mtime).
Pre-commit-safe: zero stdout when nothing changed; non-zero exit on parse error.
"""
from __future__ import annotations

import os
import sys
import tomllib
from pathlib import Path

ROOT = Path(os.environ.get("DOTFILES_ROOT") or (Path.home() / ".dotfiles"))
TEAM = ROOT / "sliced-engine/.config/sliced-engine/team.toml"
ROLES_DIR = ROOT / "prompts/roles"
VOICE_DIR = ROOT / "prompts/voice"
OUT_CLAUDE = ROOT / "claude-agents/.claude/agents"
OUT_AIDER = ROOT / "aider/.config/aider/agents"


def read_voice() -> str:
    return "\n\n".join((VOICE_DIR / f).read_text() for f in ("brand.md", "personal.md"))


def render_one(role: dict, voice: str) -> tuple[str, str]:
    name = role["name"]
    body_path = ROLES_DIR / f"{name}.md"
    if not body_path.exists():
        sys.exit(f"render-prompts: missing role body {body_path}")
    body = body_path.read_text()

    fm = [
        "---",
        f"name: {name}",
        f"description: {role['description']}",
        f"model: {role['model']}",
        "tools: " + ", ".join(role["tools"]),
    ]
    if role.get("extended_thinking"):
        fm.append("extended_thinking: true")
    fm.append("---\n")
    claude_doc = "\n".join(fm) + voice + "\n\n---\n\n" + body

    # Aider preset — flat YAML config compatible with `aider --config`.
    aider = [
        f"# Generated by render-prompts — edit the role body in prompts/roles/{name}.md",
        f"model: anthropic/{role['model']}",
        f"weak-model: ollama_chat/qwen2.5-coder:1.5b-instruct",
        f"editor-model: ollama_chat/qwen2.5-coder:7b-instruct",
        f"edit-format: diff",
        f"auto-commits: false",
        f"analytics: false",
        f"# Role: {name} — {role['description']}",
    ]
    aider_doc = "\n".join(aider) + "\n"

    return claude_doc, aider_doc


def main() -> int:
    if not TEAM.exists():
        sys.exit(f"render-prompts: missing {TEAM}")
    with TEAM.open("rb") as f:
        manifest = tomllib.load(f)

    voice = read_voice()
    OUT_CLAUDE.mkdir(parents=True, exist_ok=True)
    OUT_AIDER.mkdir(parents=True, exist_ok=True)

    n_written = 0
    for role in manifest.get("role", []):
        claude_doc, aider_doc = render_one(role, voice)
        out_c = OUT_CLAUDE / f"{role['name']}.md"
        out_a = OUT_AIDER / f"{role['name']}.yml"
        if not out_c.exists() or out_c.read_text() != claude_doc:
            out_c.write_text(claude_doc); n_written += 1
        if not out_a.exists() or out_a.read_text() != aider_doc:
            out_a.write_text(aider_doc); n_written += 1

    print(f"render-prompts: {n_written} file(s) written, {len(manifest['role'])} role(s)")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
