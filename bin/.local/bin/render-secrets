#!/usr/bin/env bash
# render-secrets — decrypt every *.sops file under known config dirs into
# its sibling plaintext path (suffix stripped). Idempotent and mode-aware:
# skips writes when content is unchanged; chmods output to 600.
#
# Convention:
#   ~/.ssh/config.d/local.conf.sops  →  ~/.ssh/config.d/local.conf
#   ~/.config/foo/bar.sops           →  ~/.config/foo/bar
#
# The *.sops files arrive in the live filesystem via stow symlinks back
# to ~/.dotfiles/<package>/...; render-secrets follows the symlink to
# decrypt, then writes the plaintext directly to the live path.
#
# Age private key lives at ~/.config/sops/age/keys.txt by default,
# overridable via SOPS_AGE_KEY_FILE.

set -euo pipefail

AGE_KEY="${SOPS_AGE_KEY_FILE:-${HOME}/.config/sops/age/keys.txt}"

if [ ! -f "${AGE_KEY}" ]; then
    echo "render-secrets: age key missing at ${AGE_KEY}" >&2
    echo "  Generate one with: age-keygen -o ${AGE_KEY} && chmod 600 ${AGE_KEY}" >&2
    exit 2
fi

if ! command -v sops >/dev/null 2>&1; then
    echo "render-secrets: sops not installed (pacman -S sops)" >&2
    exit 2
fi

export SOPS_AGE_KEY_FILE="${AGE_KEY}"

SEARCH_DIRS=(
    "${HOME}/.ssh"
    "${HOME}/.config"
)

rendered=0
scanned=0
for dir in "${SEARCH_DIRS[@]}"; do
    [ -d "${dir}" ] || continue
    while IFS= read -r -d '' src; do
        scanned=$((scanned + 1))
        dst="${src%.sops}"
        new="$(sops -d "${src}")"
        if [ -f "${dst}" ] && [ "$(cat "${dst}")" = "${new}" ]; then
            continue
        fi
        printf '%s' "${new}" > "${dst}"
        chmod 600 "${dst}"
        rendered=$((rendered + 1))
        echo "  rendered  ${dst}"
    done < <(find -L "${dir}" -name '*.sops' -print0 2>/dev/null)
done

echo "render-secrets: ${rendered} file(s) updated, ${scanned} scanned"
