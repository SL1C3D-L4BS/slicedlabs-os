#!/usr/bin/env bash
# SlicedLabs · tools · © 2026 SlicedLabs
# verify-tokens-drift — Canon §III.8 (content rides the SSOT; generated stays in sync).
# Re-run the token→artifact render cascade and assert the TRACKED generated outputs are
# byte-unchanged. A non-empty diff means system/tokens.toml changed without re-rendering,
# or a generated file was hand-edited — both break the "tokens are the single source of
# truth" rule. (Re-targeted from the retired Waybar bar to the live Cockpit generator.)
# Run from anywhere; operates on $DOTFILES_ROOT. Exit 1 on drift (CI/pre-commit).
set -euo pipefail
ROOT="${DOTFILES_ROOT:-$HOME/.dotfiles}"
cd "$ROOT"

render-quickshell >/dev/null 2>&1 || true
render-templates  >/dev/null 2>&1 || true

watched=(
    quickshell/.config/quickshell/cockpit/generated/Theme.qml
)
if ! git diff --quiet -- "${watched[@]}" 2>/dev/null; then
    echo "token-drift: a generated artifact is STALE vs tokens.toml — it has now been" >&2
    echo "  regenerated; review and stage the diff:" >&2
    git --no-pager diff --stat -- "${watched[@]}" >&2
    exit 1
fi
echo "token-drift: generated artifacts in sync with tokens.toml (Theme.qml) ✓"
