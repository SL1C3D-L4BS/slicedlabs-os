#!/usr/bin/env bash
# SlicedLabs · tools · © 2026 SlicedLabs
# cockpitctl — drive the Cockpit (Quickshell HUD) from niri keybinds.
# NOTE: distinct from `cockpit` (the workspace-scene realizer). Modal toggles go
# over Quickshell IPC; theme toggle regenerates Theme.qml (the cockpit hot-reloads).
set -euo pipefail

cmd="${1:-}"; arg="${2:-}"

case "$cmd" in
    modal)
        # legacy alias — the inspector domains now live under `cockpitctl inspect`
        [ -n "$arg" ] || { echo "cockpitctl inspect <context|net|ai|agenda>" >&2; exit 2; }
        exec qs -c cockpit ipc call cockpit inspect "$arg" ;;
    close)
        exec qs -c cockpit ipc call cockpit close ;;
    control)
        exec qs -c cockpit ipc call cockpit control ;;
    hermes)
        exec qs -c cockpit ipc call cockpit hermes ;;
    system)
        # `cockpitctl system [tab]` — tab ∈ controls|bluetooth|media|keys|governance|power
        if [ -n "$arg" ]; then exec qs -c cockpit ipc call cockpit systemTab "$arg"
        else exec qs -c cockpit ipc call cockpit system; fi ;;
    market)
        exec qs -c cockpit ipc call cockpit market ;;
    inspect)
        # `cockpitctl inspect <domain>` — domain ∈ context|net|ai|agenda
        exec qs -c cockpit ipc call cockpit inspect "$arg" ;;
    media)
        # Actionable MPRIS transport for the media HUD (P9) — drives whatever is playing
        # (spotify_player/mpd/browser) via playerctl. The cockpit pill reflects it live.
        command -v playerctl >/dev/null 2>&1 || { echo "cockpitctl media: playerctl not installed" >&2; exit 1; }
        case "${arg:-toggle}" in
            toggle|play-pause) exec playerctl play-pause ;;
            play)  exec playerctl play ;;
            pause) exec playerctl pause ;;
            next)  exec playerctl next ;;
            prev|previous) exec playerctl previous ;;
            stop)  exec playerctl stop ;;
            *) echo "cockpitctl media <toggle|play|pause|next|prev|stop>" >&2; exit 2 ;;
        esac ;;
    theme)
        f="${XDG_CACHE_HOME:-$HOME/.cache}/cockpit-theme"
        cur=$(cat "$f" 2>/dev/null || echo dark)
        case "${arg:-toggle}" in
            dark|light) new="$arg" ;;
            *) [ "$cur" = dark ] && new=light || new=dark ;;
        esac
        printf %s "$new" > "$f"
        # also keep the legacy waybar-theme file coherent for any readers
        printf %s "$new" > "${XDG_CACHE_HOME:-$HOME/.cache}/waybar-theme" 2>/dev/null || true
        exec render-quickshell --variant="$new" ;;
    *)
        echo "usage: cockpitctl {modal <name>|open <name>|close|control|hermes|system|market|media <transport>|theme [toggle|dark|light]}" >&2
        exit 2 ;;
esac
