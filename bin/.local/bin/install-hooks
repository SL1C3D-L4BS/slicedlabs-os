#!/usr/bin/env bash
# install-hooks: symlink dotfiles-tracked git hooks into a target repo.
#
# Usage:
#   install-hooks                 # pre-commit into $PWD
#   install-hooks <repo>          # pre-commit into <repo>
#   install-hooks <repo> <hook>…  # named hooks (pre-commit, post-merge, pre-push)
#
# Hooks live under ~/.dotfiles/system/git-hooks/<hook-name>.
set -euo pipefail

TARGET_REPO="${1:-$PWD}"
shift || true
HOOK_DIR_SRC="${HOME}/.dotfiles/system/git-hooks"

if [ "$#" -eq 0 ]; then
    set -- pre-commit
fi

if [ ! -e "$TARGET_REPO/.git" ]; then
    echo "install-hooks: $TARGET_REPO is not a git repo (no .git)" >&2
    exit 1
fi

GIT_DIR="$(git -C "$TARGET_REPO" rev-parse --git-dir)"
case "$GIT_DIR" in
    /*) HOOK_DST_DIR="$GIT_DIR/hooks" ;;
    *)  HOOK_DST_DIR="$TARGET_REPO/$GIT_DIR/hooks" ;;
esac
mkdir -p "$HOOK_DST_DIR"

for hook in "$@"; do
    src="$HOOK_DIR_SRC/$hook"
    dst="$HOOK_DST_DIR/$hook"
    if [ ! -f "$src" ]; then
        echo "install-hooks: source hook missing at $src" >&2
        exit 1
    fi
    if [ -L "$dst" ]; then
        ln -sfn "$src" "$dst"
    elif [ -e "$dst" ]; then
        echo "install-hooks: $dst already exists and is not a symlink." >&2
        echo "Move it aside (e.g. .${hook}.local) and rerun." >&2
        exit 2
    else
        ln -s "$src" "$dst"
    fi
    echo "install-hooks: linked $dst -> $src"
done
