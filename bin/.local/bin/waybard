#!/usr/bin/env bash
# waybard — Waybar companion daemon. Sibling to waybar-tab-watcher (which owns
# workspace→tab). Two duties, one SIGRTMIN+8 fanout:
#   1. theme auto-switch  — flip dark/light on a schedule, honouring a recent
#                           manual override (set by waybar-hud theme).
#   2. urgency monitor     — flag tabs needing attention (comms unread, failed
#                           units, imminent standup) into ~/.cache/waybar-urgent,
#                           which the always-visible alerts badge + tab caps read.
# Runs as a systemd --user service. Tunables via env: WAYBARD_TICK,
# WAYBARD_OVERRIDE_TTL; schedule via ~/.config/slicedlabs/theme-schedule.
set -u

CACHE="${XDG_CACHE_HOME:-$HOME/.cache}"
THEME="$CACHE/waybar-theme"
OVERRIDE="$CACHE/waybar-theme-override"
URGENT="$CACHE/waybar-urgent"
RENDER="$HOME/.dotfiles/bin/.local/bin/render-templates"
SCHED="$HOME/.config/slicedlabs/theme-schedule"     # "HH:MM HH:MM" = light-start dark-start
STANDUP="$HOME/.config/slicedlabs/standup-time"
TICK="${WAYBARD_TICK:-30}"
OVERRIDE_TTL="${WAYBARD_OVERRIDE_TTL:-21600}"        # 6h — manual theme wins this long

# shellcheck disable=SC1090
source "$HOME/.config/waybar/scripts/lib/tabs.env" 2>/dev/null || WAYBAR_SIGNAL=8
sig() { pkill "-SIGRTMIN+${WAYBAR_SIGNAL:-8}" waybar 2>/dev/null || true; }

desired_variant() {
    local ls ds now
    read -r ls ds < <(cat "$SCHED" 2>/dev/null); ls=${ls:-07:00}; ds=${ds:-19:00}
    now=$(date +%H:%M)
    if [[ "$now" > "$ls" && "$now" < "$ds" ]]; then echo light; else echo dark; fi
}

apply_theme() {   # auto/boot path — does NOT set the manual override marker
    printf '%s\n' "$1" > "$THEME"
    "$RENDER" --variant="$1" >/dev/null 2>&1
    killall -SIGUSR2 waybar 2>/dev/null || true
}

check_theme() {
    local want cur ov now
    want=$(desired_variant); cur=$(cat "$THEME" 2>/dev/null || echo dark)
    [[ "$want" == "$cur" ]] && return
    ov=$(cat "$OVERRIDE" 2>/dev/null || echo 0); now=$(date +%s)
    (( now - ov < OVERRIDE_TTL )) && return     # respect a recent manual toggle
    apply_theme "$want"
}

check_urgency() {
    local u=() title fu now target hhmm diff new old
    if pgrep -xi discord >/dev/null 2>&1; then
        title=$(niri msg --json windows 2>/dev/null | jq -r '.[]|select((.app_id//"")|ascii_downcase|contains("discord"))|.title' 2>/dev/null | head -1)
        [[ "$title" =~ \(([0-9]+)\) ]] && u+=(comms)
    fi
    fu=$(( $(systemctl --failed --no-legend 2>/dev/null | wc -l) + $(systemctl --user --failed --no-legend 2>/dev/null | wc -l) ))
    (( fu > 0 )) && u+=(monitoring)
    hhmm=$(cat "$STANDUP" 2>/dev/null || echo 09:30); now=$(date +%s)
    target=$(date -d "today $hhmm" +%s 2>/dev/null || echo "$now")
    (( target <= now )) && target=$(date -d "tomorrow $hhmm" +%s 2>/dev/null || echo "$now")
    diff=$(( target - now )); (( diff < 900 )) && u+=(agenda)

    new="${u[*]}"; old=$(cat "$URGENT" 2>/dev/null || echo "")
    [[ "$new" != "$old" ]] && { printf '%s\n' "$new" > "$URGENT"; sig; }
}

# Re-apply a persisted non-default theme once on boot (default render is dark).
[[ "$(cat "$THEME" 2>/dev/null || echo dark)" == light ]] && apply_theme light

while true; do
    check_theme
    check_urgency
    sleep "$TICK"
done
