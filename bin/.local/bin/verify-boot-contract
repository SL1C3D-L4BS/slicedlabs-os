#!/usr/bin/env bash
# SlicedLabs · tools · © 2026 SlicedLabs
# verify-boot-contract — the login boot contract holds (Track 9.4): the working
# stacks (coding · browser · research) EAGER-STAGE at login; everything else (incl.
# monitoring) is on-demand via `cockpit <ws>`; the scene launcher + autotiler are
# spawned by niri; and every auto workspace declares its scene + services.
# Track B P1 adds: the WINDOW-MATH invariants (full-width column + presets + radius)
# and the MUSIC posture (nothing autoplays at login; ambient only fills silence).
# Folded into verify-all. SSOT: workspaces.toml + niri config.
set -uo pipefail
ROOT="${DOTFILES_ROOT:-$HOME/.dotfiles}"
REG="$ROOT/sliced-engine/.config/sliced-engine/workspaces.toml"
NIRI="$ROOT/niri/.config/niri/config.kdl"
[ -f "$NIRI" ] || NIRI="$ROOT/niri/.config/niri/config.kdl.tmpl"
fail=0
ok() { echo "  ✓ $1"; }
no() { echo "  ✗ $1" >&2; fail=1; }

py() { python3 -c "$1" 2>/dev/null; }

# 1) [meta].auto is EMPTY — project-scoped lean login (2026-06-03). Nothing eager-stages;
#    each project-scoped ws is summoned BOUND to a project via `cockpit <ws>`. A non-empty
#    auto would reintroduce the context-free "generalized station" + the login-storm risk.
auto=$(py "import tomllib;print(' '.join(tomllib.load(open('$REG','rb'))['meta']['auto']))")
[ -z "${auto// /}" ] && ok "lean login: [meta].auto empty (project-scoped summon)" \
    || no "[meta].auto must be empty for project-scoped lean login (got: $auto)"

# 2) niri spawns the scene launcher + autotiler at startup. monitoring is NOT eager —
#    the webstack/monitoring-stack era ended 2026-05-31; it's an on-demand DP-2 cockpit.
for s in niri-workspace-launcher niri-autotile; do
    grep -q "spawn-at-startup \"$s\"" "$NIRI" && ok "niri spawn-at-startup $s" \
        || no "niri missing spawn-at-startup $s"
done
echo " $auto " | grep -q " monitoring " && no "monitoring must NOT be eager (should be on-demand)" \
    || ok "monitoring is on-demand (not in [meta].auto)"

# 3) project-scoped workspaces declare project_scoped + default_project + a scene, so a
#    summon binds the whole deck to a project (the new contract replacing eager-staging).
for ws in coding engine research; do
    ps=$(py "import tomllib;w=tomllib.load(open('$REG','rb'))['workspaces'].get('$ws',{});print(1 if w.get('project_scoped') and w.get('default_project') and (w.get('apps') or w.get('delegate')) else 0)")
    [ "${ps:-0}" = "1" ] && ok "'$ws' project-scoped (default_project + scene)" \
        || no "'$ws' missing project_scoped/default_project/scene"
done

# 4) coding stack starts its backing services; monitoring is a DP-2 cockpit that boots
#    the observability stack ON DEMAND (dev-stack-obs in its scene services, not at login).
csvc=$(py "import tomllib;print(' '.join(tomllib.load(open('$REG','rb'))['workspaces']['coding'].get('services',[])))")
echo " $csvc " | grep -q " dev-stack-data " && ok "coding stack starts dev-stack-data" \
    || no "coding missing dev-stack-data service ($csvc)"
mon=$(py "import tomllib;print(tomllib.load(open('$REG','rb'))['workspaces'].get('monitoring',{}).get('output',''))")
[ "$mon" = "DP-2" ] && ok "monitoring scene on DP-2" || no "monitoring scene not on DP-2 ($mon)"
msvc=$(py "import tomllib;print(' '.join(tomllib.load(open('$REG','rb'))['workspaces'].get('monitoring',{}).get('services',[])))")
echo " $msvc " | grep -q " dev-stack-obs " && ok "monitoring boots dev-stack-obs on demand" \
    || no "monitoring missing dev-stack-obs service ($msvc)"
if systemctl --user list-dependencies default.target 2>/dev/null | grep -q dev-stack-obs; then
    no "dev-stack-obs still in default.target (autostarts at login)"
else
    ok "dev-stack-obs NOT autostarted at login (lean boot)"
fi

# 5) window math (Track B P1) — a single window opens full-width on the big monitor,
#    Mod+R cycles presets, corners clip to the radius. niri is the SSOT.
grep -qE 'proportion 1\.0' "$NIRI" \
    && ok "niri opens a single window full-width (default-column-width proportion 1.0)" \
    || no "niri default-column-width is not proportion 1.0 (windows won't open full)"
grep -qE 'preset-column-widths' "$NIRI" \
    && ok "niri preset-column-widths present (Mod+R cycles 0.25/0.33/0.5/0.67)" \
    || no "niri preset-column-widths missing"
grep -qE 'switch-preset-column-width' "$NIRI" \
    && ok "niri Mod+R width-preset bind present" || no "niri width-preset bind missing"
grep -qE 'geometry-corner-radius' "$NIRI" \
    && ok "niri geometry-corner-radius set (windows clip to radius)" || no "niri corner-radius missing"

# 6) music posture (Track B P1) — daemon-on-demand: NOTHING autoplays at login. mpd
#    restores to PAUSED, no player sits in any autostart path, and the only music a
#    scene starts is playerctl-guarded ambient that fills silence (never plays over you).
players='mpd|mpv|spotify|playerctl|tunes|cinema|cmus|ncmpcpp|\bmusic\b'
mpdconf="$ROOT/mpd/.config/mpd/mpd.conf"
grep -qE '^[[:space:]]*restore_paused[[:space:]]+"yes"' "$mpdconf" 2>/dev/null \
    && ok "mpd restore_paused=yes (restores PAUSED — no autoplay on restart)" \
    || no "mpd may autoplay on restart (restore_paused != yes)"
if grep -E 'spawn-at-startup' "$NIRI" | grep -vE '^[[:space:]]*//' | grep -qiE "$players"; then
    no "a media player autostarts in niri spawn-at-startup"
else
    ok "no media player in niri spawn-at-startup"
fi
if grep -rhiE '^Exec=' "$ROOT/autostart/.config/autostart/" 2>/dev/null | grep -qiE "$players"; then
    no "a media player is in XDG autostart (.desktop Exec)"
else
    ok "no media player in XDG autostart"
fi
grep -q 'playerctl -a status' "$ROOT/bin/.local/bin/lib/scene.sh" \
    && ok "scene ambient is playerctl-guarded (fills silence only — never plays over you)" \
    || no "scene ambient is NOT guarded (could autoplay over active audio)"

[ $fail -eq 0 ] && echo "boot-contract: stacks eager-stage + window-math + music posture ✓"
exit $fail
