#!/usr/bin/env bash
# SlicedLabs · tools · © 2026 SlicedLabs
# verify-secrets — the secrets-hygiene invariant: no secret material is tracked
# in plaintext, the sops/age encryption is sound and recoverable, and commit-time
# scanning is wired. Codifies what's already true (sops/age + the gitleaks
# pre-commit hook + the recovery.md identity files) so it can't silently rot.
# SSOT: .sops.yaml · system/git-hooks/pre-commit · render-secrets · system/recovery.md.
set -uo pipefail
fail=0
ok() { echo "  ✓ $1"; }
no() { echo "  ✗ $1" >&2; fail=1; }

ROOT="${DOTFILES_ROOT:-${HOME}/.dotfiles}"
AGE_KEY="${SOPS_AGE_KEY_FILE:-${HOME}/.config/sops/age/keys.txt}"

# 1) commit-time leak scanning is wired (gitleaks via the pre-commit hook)
command -v gitleaks >/dev/null 2>&1 && ok "gitleaks present" || no "gitleaks not installed"
hook="${ROOT}/.git/hooks/pre-commit"
if [ -e "$hook" ] && grep -qi gitleaks "$(readlink -f "$hook" 2>/dev/null)" 2>/dev/null; then
  ok "pre-commit gitleaks hook wired"
else
  no "pre-commit gitleaks hook not wired"
fi

# 2) the encryption policy exists
if [ -f "${ROOT}/.sops.yaml" ] && grep -q 'creation_rules' "${ROOT}/.sops.yaml"; then
  ok ".sops.yaml present with creation_rules"
else
  no ".sops.yaml missing or has no creation_rules"
fi

# 3) the age private key — present, locked down (mode 600)
if [ -f "$AGE_KEY" ]; then
  perm=$(stat -c '%a' "$AGE_KEY" 2>/dev/null)
  [ "$perm" = 600 ] && ok "age key present (mode 600)" || no "age key mode $perm (want 600)"
else
  no "age key missing at $AGE_KEY"
fi

# 4) every TRACKED *.sops file is encrypted, decrypts with the key, and its
#    decrypted sibling is NOT tracked (no plaintext secret in the repo)
mapfile -t sopsf < <(git -C "$ROOT" ls-files -- '*.sops' 2>/dev/null)
if [ "${#sopsf[@]}" -eq 0 ]; then
  no "no tracked *.sops files (expected the AI keys + ssh local.conf)"
else
  for rel in "${sopsf[@]}"; do
    f="${ROOT}/${rel}"
    if ! grep -q 'ENC\[AES256' "$f" 2>/dev/null; then no "$rel is not encrypted"; continue; fi
    if ! SOPS_AGE_KEY_FILE="$AGE_KEY" sops -d "$f" >/dev/null 2>&1; then no "$rel does not decrypt with the age key"; continue; fi
    if git -C "$ROOT" ls-files --error-unmatch -- "${rel%.sops}" >/dev/null 2>&1; then
      no "decrypted plaintext sibling is TRACKED: ${rel%.sops}"; continue
    fi
    ok "$rel — encrypted · decryptable · plaintext untracked"
  done
fi

# 5) the irreplaceable identity files exist (recovery.md §five files)
[ "$(gpg --list-secret-keys 2>/dev/null | grep -c '^sec')" -ge 1 ] && ok "GPG secret key present (pass is usable)" || no "no GPG secret key"
[ -r "${HOME}/.ssh/github_ed25519" ] && ok "GitHub SSH key present" || no "GitHub SSH key missing"

[ $fail -eq 0 ] && echo "secrets: nothing tracked in plaintext · sops sound · scanning wired ✓"
exit $fail
