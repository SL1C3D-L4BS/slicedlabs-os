#!/usr/bin/env bash
# waybar-tab-watcher — drive Waybar's active tab from Niri's focused workspace.
#
# State machine:
#   • Single source of truth: $HOME/.cache/waybar-active-tab → one of
#     engine | comms | stream | monitoring | gaming
#   • Driver: subscribe to `niri msg --json event-stream`. On focus-relevant
#     events, query workspaces, find is_focused, map its name → tab.
#   • Sticky: if the focused workspace is unnamed (numeric scratch), the active
#     tab is unchanged.
#   • Refresh: on tab change, write the state file and send SIGRTMIN+8 to
#     waybar; all tab-aware modules re-evaluate visibility in one pass.

set -u

STATE_FILE="${XDG_CACHE_HOME:-$HOME/.cache}/waybar-active-tab"
mkdir -p "$(dirname "$STATE_FILE")"

KNOWN_TABS=(engine comms stream monitoring gaming coding browser)

is_known() {
    local name="$1"
    for t in "${KNOWN_TABS[@]}"; do
        [[ "$name" == "$t" ]] && return 0
    done
    return 1
}

derive_active_tab() {
    niri msg --json workspaces 2>/dev/null \
        | jq -r '.[] | select(.is_focused == true) | .name // empty' \
        | head -1
}

apply_state() {
    local new="$1"
    is_known "$new" || return 0           # sticky on unknown/null
    local cur=""
    [[ -f "$STATE_FILE" ]] && cur="$(<"$STATE_FILE")"
    [[ "$cur" == "$new" ]] && return 0    # no change → no signal
    printf '%s\n' "$new" > "$STATE_FILE"
    pkill -SIGRTMIN+8 waybar 2>/dev/null || true
}

# Initial pass — populate state file before any events fire.
initial=$(derive_active_tab)
if [[ -n "$initial" ]]; then
    apply_state "$initial"
elif [[ ! -f "$STATE_FILE" ]]; then
    # Sensible default for first run when nothing is focused yet.
    printf 'engine\n' > "$STATE_FILE"
fi

# Event loop. niri exits on shutdown / restart → systemd restarts us.
niri msg --json event-stream | while IFS= read -r evt; do
    case "$evt" in
        *WorkspaceActivated*|*WorkspacesChanged*)
            new=$(derive_active_tab)
            [[ -n "$new" ]] && apply_state "$new"
            ;;
    esac
done
