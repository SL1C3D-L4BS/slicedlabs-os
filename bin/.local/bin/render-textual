#!/usr/bin/env python3
"""render-textual — bake the Textual TUI design system from tokens.toml.

The second render target of the design language (Quickshell is the first). Mirrors
render-quickshell: system/tokens.toml is the single source of truth; this emits a
shared, baked design layer that every SlicedLabs TUI imports so they share ONE
chrome — and so the slicedlabs package no longer needs tokens.toml at runtime (it
ships its own design, regenerated on token change). Emits into the package:

  1. slicedlabs_team/generated/palette.py   baked dark+light colours, brand map,
                                            icon glyphs, motion durations (seconds)
  2. slicedlabs_team/generated/theme.tcss   shared Textual stylesheet (glass panel,
                                            titles, per-brand accent classes)

Both variants are baked; the live dark/light pick happens at runtime from
~/.cache/ricing-variant (see theme.py). Override roots with DOTFILES_ROOT.
"""
from __future__ import annotations

import os
import sys
import tomllib
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent / "lib"))
import color  # noqa: E402 — local OKLCH→sRGB lib alongside this script

DOTFILES = Path(os.environ.get("DOTFILES_ROOT") or (Path.home() / ".dotfiles"))
TOKENS = DOTFILES / "system" / "tokens.toml"
PKG = DOTFILES / "slicedlabs-team" / "slicedlabs_team"
OUT = PKG / "generated"

# Workspace / HUD name → [color] token key (brand map) — mirrors render-quickshell.
# Identity is its OWN ramp now (status ≠ identity); each maps to its same-named hue.
BRAND = {
    "coding": "coding", "research": "research", "engine": "engine",
    "browser": "browser", "monitoring": "monitoring", "streaming": "streaming",
    "gaming": "gaming", "media": "media",
    "net": "net", "ai": "ai", "agenda": "agenda",
}


def _hex(v: object) -> object:
    """Normalise an oklch()/hex colour to '#RRGGBB'; pass anything else through."""
    h = color.to_hex(v)
    return h if h else v


def _hexify(d: dict) -> dict:
    return {k: _hex(v) for k, v in d.items()}


def merged(t: dict, base: str, light: str, variant: str) -> dict:
    """The base section overlaid by its *_light companion for variant=light."""
    d = dict(t.get(base, {}))
    if variant == "light":
        d.update(t.get(light, {}))
    return d


def py_dict(d: dict[str, object], indent: str = "    ") -> str:
    return "{\n" + "".join(f'{indent}{k!r}: {v!r},\n' for k, v in d.items()) + "}"


def build_palette(t: dict) -> str:
    color_dark = _hexify(merged(t, "color", "color_light", "dark"))
    color_light = _hexify(merged(t, "color", "color_light", "light"))
    semantic_dark = _hexify(merged(t, "semantic", "semantic_light", "dark"))
    semantic_light = _hexify(merged(t, "semantic", "semantic_light", "light"))
    glass_dark = merged(t, "glass", "glass_light", "dark")
    glass_light = merged(t, "glass", "glass_light", "light")
    icon = dict(t.get("icon", {}))
    font = dict(t.get("font", {}))
    motion_ms = t.get("motion", {})
    # durations → seconds (Textual animations take seconds); skip the easing string.
    motion = {k[:-3] if k.endswith("_ms") else k: round(v / 1000, 3)
              for k, v in motion_ms.items() if isinstance(v, (int, float))}

    L: list[str] = []
    L.append("# GENERATED by render-textual from system/tokens.toml — do not edit.")
    L.append('"""Baked SlicedLabs design tokens (dark + light) for every TUI."""')
    L.append("from __future__ import annotations")
    L.append("")
    L.append(f"COLOR_DARK: dict[str, str] = {py_dict(color_dark)}")
    L.append("")
    L.append(f"COLOR_LIGHT: dict[str, str] = {py_dict(color_light)}")
    L.append("")
    L.append(f"SEMANTIC_DARK: dict[str, str] = {py_dict(semantic_dark)}")
    L.append("")
    L.append(f"SEMANTIC_LIGHT: dict[str, str] = {py_dict(semantic_light)}")
    L.append("")
    L.append(f"GLASS_DARK: dict[str, object] = {py_dict(glass_dark)}")
    L.append("")
    L.append(f"GLASS_LIGHT: dict[str, object] = {py_dict(glass_light)}")
    L.append("")
    L.append(f"BRAND: dict[str, str] = {py_dict(BRAND)}")
    L.append("")
    L.append(f"ICON: dict[str, str] = {py_dict(icon)}")
    L.append("")
    L.append(f"FONT: dict[str, str] = {py_dict(font)}")
    L.append("")
    L.append(f"MOTION: dict[str, float] = {py_dict(motion)}  # seconds")
    L.append("")
    L.append("")
    L.append("def palette(variant: str = 'dark') -> dict[str, str]:")
    L.append('    """The colour map for the active variant."""')
    L.append("    return COLOR_LIGHT if variant == 'light' else COLOR_DARK")
    L.append("")
    L.append("")
    L.append("def glass(variant: str = 'dark') -> dict[str, object]:")
    L.append("    return GLASS_LIGHT if variant == 'light' else GLASS_DARK")
    L.append("")
    L.append("")
    L.append("def semantic(variant: str = 'dark') -> dict[str, str]:")
    L.append('    """Semantic role tier (bg/text/border + danger/info) for the variant."""')
    L.append("    return SEMANTIC_LIGHT if variant == 'light' else SEMANTIC_DARK")
    L.append("")
    L.append("")
    L.append("def brand_color(name: str, variant: str = 'dark') -> str:")
    L.append('    """Workspace/HUD identity hue, e.g. brand_color(\'coding\')."""')
    L.append("    p = palette(variant)")
    L.append("    return p.get(BRAND.get(name, ''), p['primary'])")
    L.append("")
    L.append("")
    L.append("def icon(name: str) -> str:")
    L.append("    return ICON.get(name, '')")
    L.append("")
    return "\n".join(L)


def build_tcss(t: dict) -> str:
    """Shared Textual stylesheet. Structural colours use Textual's built-in theme
    $variables ($primary/$panel/…, which follow dark/light automatically). Brand
    accents use $hue-<name> variables DEFINED here (baked from tokens) — they must
    be defined in the stylesheet because CSS_PATH is parsed before a custom theme's
    variables exist."""
    c = _hexify(merged(t, "color", "color_light", "dark"))  # brand hues baked (dark)
    s = _hexify(merged(t, "semantic", "semantic_light", "dark"))  # semantic role tier
    L: list[str] = []
    L.append("/* GENERATED by render-textual from system/tokens.toml — do not edit. */")
    L.append("/* Import via the App's CSS_PATH alongside the app's own .tcss. */")
    L.append("")
    L.append("/* Brand identity hues, baked from tokens (used by the .brand-* classes). */")
    for name, key in BRAND.items():
        L.append(f"$hue-{name}: {c.get(key, c['primary'])};")
    L.append("")
    L.append("/* Semantic role tier ($sl-*), baked — bind to ROLES, not raw hues. */")
    for k, v in s.items():
        L.append(f"$sl-{k.replace('_', '-')}: {v};")
    L.append("")
    L.append("/* Frosted Liquid-Glass panel (TUI approximation: boosted surface + rim). */")
    L.append(".sl-glass {")
    L.append("    background: $panel;")
    L.append("    border: round $primary 35%;")
    L.append("    padding: 1 2;")
    L.append("}")
    L.append("")
    L.append(".sl-title { text-style: bold; color: $foreground; }")
    L.append(".sl-subtitle { color: $secondary; text-style: bold; }")
    L.append(".sl-muted { color: $text-muted; }")
    L.append(".sl-rule { color: $primary; }")
    L.append(".sl-ok { color: $success; }")
    L.append(".sl-warn { color: $warning; }")
    L.append(".sl-err { color: $error; }")
    L.append("")
    L.append("/* Brand identity accents — one class per workspace/HUD hue. */")
    for name in BRAND:
        L.append(f".brand-{name} {{ color: $hue-{name}; }}")
    L.append("")
    L.append("/* Capsule PILLS — the Liquid-Glass pill atom in TUI form, matching the")
    L.append("   Cockpit / zjstatus / tide capsules. `.sl-pill` is a rounded-border capsule")
    L.append("   (same round language as .sl-glass); `.sl-chip` is a filled inline tag. */")
    L.append(".sl-pill {")
    L.append("    border: round $sl-border-tertiary;")
    L.append("    color: $sl-text-secondary;")
    L.append("    padding: 0 1;")
    L.append("}")
    L.append(".sl-pill.-active { border: round $primary; color: $foreground; text-style: bold; }")
    L.append(".sl-pill.-ok   { border: round $success; color: $success; }")
    L.append(".sl-pill.-warn { border: round $warning; color: $warning; }")
    L.append(".sl-pill.-err  { border: round $error;   color: $error; }")
    L.append(".sl-chip {")
    L.append("    background: $primary;")
    L.append("    color: $background;")
    L.append("    padding: 0 1;")
    L.append("    text-style: bold;")
    L.append("}")
    L.append(".sl-chip.-muted { background: $sl-bg-tertiary; color: $sl-text-secondary; text-style: none; }")
    L.append("")
    return "\n".join(L)


def main() -> int:
    if not TOKENS.is_file():
        print(f"render-textual: tokens file missing: {TOKENS}")
        return 2
    with TOKENS.open("rb") as f:
        t = tomllib.load(f)

    OUT.mkdir(parents=True, exist_ok=True)
    (OUT / "__init__.py").write_text(
        '"""Generated design layer (render-textual). Do not edit by hand."""\n'
    )
    (OUT / "palette.py").write_text(build_palette(t))
    (OUT / "theme.tcss").write_text(build_tcss(t))
    n_brand = len(BRAND)
    n_color = len(t.get("color", {}))
    print(f"✓ render-textual: {n_color} colours × 2 variants, {n_brand} brand hues, "
          f"{len(t.get('icon', {}))} glyphs")
    print(f"  → {(OUT / 'palette.py').relative_to(DOTFILES)}")
    print(f"  → {(OUT / 'theme.tcss').relative_to(DOTFILES)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
