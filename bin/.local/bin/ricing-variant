#!/usr/bin/env bash
# ricing-variant — switch the workstation between dark and light color variants.
#
# Usage: ricing-variant {dark|light}
#
# Re-renders every .tmpl file under ~/.dotfiles with the chosen variant
# (defaults to dark in tokens.toml) then reloads Waybar + Niri + Ghostty.
# The choice is sticky: re-running ./render-templates without args defaults
# back to dark, so this script persists the choice in
# ~/.cache/ricing-variant. Other shells/scripts can read that file to know
# the current state.
set -euo pipefail

VARIANT="${1:-}"
CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/ricing-variant"

if [[ -z "$VARIANT" ]]; then
    # No arg → toggle from cached state (default dark).
    cur=$(cat "$CACHE" 2>/dev/null || echo dark)
    if [[ "$cur" == "dark" ]]; then VARIANT="light"; else VARIANT="dark"; fi
fi

case "$VARIANT" in
    dark|light) ;;
    *) echo "ricing-variant: usage: $0 {dark|light}" >&2; exit 2 ;;
esac

echo "ricing-variant: switching to '$VARIANT'..."

render-templates --variant="$VARIANT"
echo "$VARIANT" > "$CACHE"

# Live reload — Waybar style.css can hot-reload; Waybar config.jsonc cannot,
# so we hard-restart Waybar to be safe. Niri config reloads via IPC.
pkill -SIGUSR2 waybar 2>/dev/null || true
sleep 0.2
pkill waybar 2>/dev/null || true
sleep 0.3
nohup waybar </dev/null >/tmp/waybar.log 2>&1 &
disown 2>/dev/null || true

niri msg action load-config-file 2>/dev/null || true

# Mako reloads on its own
makoctl reload 2>/dev/null || true

notify-send "Ricing" "Variant: $VARIANT (re-render complete)"
echo "ricing-variant: done — variant cached at $CACHE"
