#!/usr/bin/env python3
# SlicedLabs · tools · © 2026 SlicedLabs
"""render-engine-palette — generate the [ENGINE] UI palette from tokens.toml.

Mirrors render-templates / render-prompts: system/tokens.toml is the single
source of truth for the workstation design system; this emits a zero-dependency
Rust palette (const data) into engine-ui so the engine's in-app chrome stays in
lockstep with Waybar / Niri / Neovim. Re-run via `just gen-palette` in the
engine, or directly. Override paths with DOTFILES_ROOT / ENGINE_ROOT.
"""
from __future__ import annotations

import os
import re
import sys
import tomllib
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent / "lib"))
import color as colorlib  # noqa: E402 — local OKLCH→sRGB lib alongside this script

DOTFILES = Path(os.environ.get("DOTFILES_ROOT") or (Path.home() / ".dotfiles"))
ENGINE = Path(os.environ.get("ENGINE_ROOT") or (Path.home() / "SlicedLabs/tools/slicedengine"))
TOKENS = DOTFILES / "system/tokens.toml"
OUT = ENGINE / "crates/engine-ui/src/theme/palette.rs"

HEX = re.compile(r"^#([0-9a-fA-F]{6})$")

# [color] hue anchors that derive tonal ramps (every [family] key does too) —
# mirrors render-templates / render-quickshell / render-textual (one ramp law).
RAMP_HUES = (
    "coding", "research", "engine", "browser",
    "monitoring", "streaming", "gaming", "media",
    "primary", "secondary", "tertiary", "error", "success",
)


def rust_str(v: str) -> str:
    return str(v).replace("\\", "\\\\").replace('"', '\\"')


def main() -> int:
    t = tomllib.loads(TOKENS.read_text())
    L: list[str] = []
    L += [
        "// GENERATED from ~/.dotfiles/system/tokens.toml by `render-engine-palette`.",
        "// DO NOT EDIT — edit tokens.toml then run `just gen-palette`.",
        "#![allow(dead_code)]",
        "",
        "/// 8-bit sRGB colour with alpha.",
        "#[derive(Clone, Copy, Debug, PartialEq, Eq)]",
        "pub struct Rgba {",
        "    /// Red channel (0-255).",
        "    pub r: u8,",
        "    /// Green channel (0-255).",
        "    pub g: u8,",
        "    /// Blue channel (0-255).",
        "    pub b: u8,",
        "    /// Alpha channel (0-255).",
        "    pub a: u8,",
        "}",
        "",
        "impl Rgba {",
        "    /// Opaque colour from a packed `0xRRGGBB` literal.",
        "    pub const fn rgb(v: u32) -> Self {",
        "        Self { r: (v >> 16) as u8, g: (v >> 8) as u8, b: v as u8, a: 255 }",
        "    }",
        "}",
        "",
        "/// Semantic colours (tokens.toml `[color]`).",
        "pub mod color {",
        "    use super::Rgba;",
    ]
    n_col = 0
    for k, v in t["color"].items():
        hexed = colorlib.to_hex(v)  # oklch() anchors bake to sRGB hex (v3)
        if hexed:
            n_col += 1
            L.append(f"    /// `{hexed}`")
            L.append(f"    pub const {k.upper()}: Rgba = Rgba::rgb(0x{hexed.lstrip('#').upper()});")
    L += ["}", "",
          "/// Family accents — Liquid Retina v3 half-spokes (tokens.toml `[family]`).",
          "pub mod family {",
          "    use super::Rgba;"]
    fam = t.get("family", {})
    for k, v in fam.items():
        hexed = colorlib.to_hex(v)
        if hexed:
            L.append(f"    /// `{hexed}`")
            L.append(f"    pub const {k.upper()}: Rgba = Rgba::rgb(0x{hexed.lstrip('#').upper()});")
    L += ["}", "",
          "/// Derived tonal ramps (v3) — 10 steps per hue, lib/color.ramp() law.",
          "pub mod ramp {",
          "    use super::Rgba;"]
    anchors: dict[str, object] = {k: t["color"][k] for k in RAMP_HUES if k in t["color"]}
    anchors.update(fam)
    n_ramp = 0
    for name, value in anchors.items():
        hexed = colorlib.to_hex(value)
        if not hexed:
            continue
        n_ramp += 1
        for step, hx in colorlib.ramp_for_hex(hexed).items():
            L.append(f"    /// `{hx}`")
            L.append(f"    pub const {name.upper()}_{step}: Rgba = Rgba::rgb(0x{hx.lstrip('#').upper()});")
    L += ["}", "", "/// Nerd-Font glyphs (tokens.toml `[icon]`).", "pub mod icon {"]
    for k, v in t["icon"].items():
        L.append(f"    /// `{rust_str(v)}`")
        L.append(f'    pub const {k.upper()}: &str = "{rust_str(v)}";')
    L += ["}", "", "/// Geometry in logical px (tokens.toml `[geom]`).", "pub mod geom {"]
    for k, v in t["geom"].items():
        if isinstance(v, int):
            L.append(f"    /// `{v}` px")
            L.append(f"    pub const {k.upper()}: u32 = {v};")
    L += ["}", "", "/// Motion durations in ms + easing curve (tokens.toml `[motion]`).", "pub mod motion {"]
    for k, v in t["motion"].items():
        if isinstance(v, int):
            L.append(f"    /// `{v}` ms")
            L.append(f"    pub const {k.upper()}: u32 = {v};")
        else:
            L.append(f"    /// `{rust_str(v)}`")
            L.append(f'    pub const {k.upper()}: &str = "{rust_str(v)}";')
    L.append("}")

    OUT.parent.mkdir(parents=True, exist_ok=True)
    OUT.write_text("\n".join(L) + "\n")
    print(f"render-engine-palette: {OUT.relative_to(ENGINE)} "
          f"({n_col} colours, {len(fam)} families, {n_ramp} ramps, "
          f"{len(t['icon'])} icons, {len(t['geom'])} geom, {len(t['motion'])} motion)")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
