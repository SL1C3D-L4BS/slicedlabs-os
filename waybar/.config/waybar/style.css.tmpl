/* <<< GENERATED:fusion <<< */

/* ============================================================================
 * Liveness motion classes — bare classes so animation/box-shadow apply over
 * the base id rule (which only sets colour/bg). Colour for these states is set
 * by the per-module overrides further down.
 * ========================================================================== */
.building  { animation: pulse-build {{motion.pulse_ms}}ms {{motion.ease}} infinite; }
.recording { animation: pulse-rec   {{motion.pulse_ms}}ms {{motion.ease}} infinite; }
.live      { animation: pulse-live  {{motion.pulse_ms}}ms {{motion.ease}} infinite; }

/* Workstation widget — always-visible left status badge. */
#custom-workstation {
    padding: 0 {{geom.pad_x}}px;
    font-weight: 600;
    color: {{color.coding}};
}
#custom-workstation.active    { color: {{color.success}}; }
#custom-workstation.warning   { color: {{color.honey}}; }
#custom-workstation.critical  { color: {{color.error}}; font-weight: bold; }

/* Always-visible urgency badge (left) — glows while any tab is flagged. */
#custom-alerts        { padding: 0 10px; color: {{color.tertiary}}; }
#custom-alerts.urgent { color: {{color.tertiary}}; font-weight: bold; animation: glow-urgent {{motion.pulse_ms}}ms {{motion.ease}} infinite; }

/* Pomodoro chips — colour reflects state. */
#custom-coding-pomo.work,   #custom-ai-pomo.work    { color: {{color.coding}}; }
#custom-coding-pomo.break,  #custom-ai-pomo.break   { color: {{color.success}}; }
#custom-coding-pomo.paused, #custom-ai-pomo.paused  { color: {{color.fg_muted}}; }

/* --- Shared state classes — same vocab across all tabs ------------------- */
.empty    { color: {{color.inactive}}; }
.ok       { color: {{color.fg_muted}}; }
.info     { color: {{color.secondary}}; }
.alert    { color: {{color.tertiary}}; font-weight: bold; }
.critical { color: {{color.error}}; font-weight: bold; }

/* --- Per-module state-class recolours (higher specificity than base) ----- */
#custom-gaming-status.idle    { color: {{color.fg_muted}}; }
#custom-gaming-status.playing {
    color: {{color.tertiary}};
    border-left: {{geom.border}}px solid {{color.primary}};
}

#custom-gpu-stats.critical,
#custom-cpu-temp.critical {
    color: {{color.error}};
    font-weight: bold;
}

#custom-gamemode.on  { color: {{color.fg}}; background: {{color.selection}}; }
#custom-gamemode.off { color: {{color.fg_muted}}; }
#custom-gamemode:hover {
    color: {{color.secondary}};
    background: {{color.warm_shadow}};
}

#custom-ds4-battery.critical { color: {{color.error}}; }

#custom-engine-build.ok        { color: {{color.success}}; }
#custom-engine-build.critical  { color: {{color.error}}; font-weight: bold; }
#custom-engine-build.info      { color: {{color.mist}}; }
#custom-engine-build.building  { color: {{color.mist}}; }

#custom-comms-zoom.alert {
    color: {{color.secondary}};
    border-left: {{geom.border}}px solid {{color.success}};
}
#custom-comms-matrix.alert { color: {{color.secondary}}; font-weight: bold; }

#custom-stream-obs.recording, #custom-stream-uptime.recording { color: {{color.tertiary}}; font-weight: bold; }
#custom-stream-obs.live,      #custom-stream-uptime.live      { color: {{color.error}};    font-weight: bold; }

#custom-stream-bitrate.ok       { color: {{color.success}}; }
#custom-stream-bitrate.alert    { color: {{color.honey}}; }
#custom-stream-bitrate.critical { color: {{color.error}}; font-weight: bold; }

#custom-mon-disk-pressure.alert    { color: {{color.honey}}; }
