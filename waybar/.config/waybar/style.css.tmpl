/* [ENGINE] platform — Waybar style · design tokens from system/tokens.toml
 *
 * Mathematically-derived layout; every value derives from the 4px atomic unit.
 * The CENTER is the active tab's FUSED instrument cluster: a brand-capped pill
 * whose supporting modules are segmented (no inter-gap, thin dividers, shared
 * brand under-border, rounded ends) — the same technique as the cpu|mem|temp
 * cluster, generalised per tab. Motion is signal-only (breathe/glow on live
 * states, hover-lift, tab-in).
 *
 * The GENERATED:* regions below are produced by `render-waybar` from tabs.toml
 * — do not hand-edit between the markers. Pipeline: render-waybar && render-templates
 */

* {
    font-family: "{{font.mono}}", monospace;
    font-size: {{font.ui_size}}px;
    border: none;
    border-radius: 0;
    min-height: 0;
}

/* Bar surface transparent — every chip carries its own fill, so the bar reads
   as floating pills over the wallpaper. */
window#waybar {
    background: transparent;
    color: {{color.fg}};
}

/* ============================================================================
 * Center placement — modules-center is a GTK center-widget: Waybar centers the
 * active tab's fused pill AS A GROUP in the bar automatically. DO NOT put a
 * min-width on .modules-left: a center-widget's usable width is (bar − 2×left),
 * so reserving ~half the bar on the left clips the centre to ~320px and makes
 * every tab cluster invisible (the 2026-05-29 regression). The window title is
 * already bounded by niri/window "max-length" (config.jsonc), so the left
 * cluster can't balloon and squeeze the centre. The brand word sits left-of-
 * centre within the centred pill — by design; see render-waybar (cap margin).
 * ========================================================================== */

/* ============================================================================
 * Workspaces (left) — container pill enclosing the named workspace tiles
 * ========================================================================== */
#workspaces {
    background: {{color.bg_alt_light}};
    border-radius: {{geom.radius_lg}}px;
    margin: 4px 4px 4px {{geom.gap}}px;
    padding: 3px;
}

#workspaces button {
    min-height: 22px;
    padding: 0 8px;
    margin: 0 2px;
    color: {{color.fg_muted}};
    background: transparent;
    border-radius: {{geom.radius_sm}}px;
    transition: background-color {{motion.quick_ms}}ms {{motion.ease}},
                color {{motion.quick_ms}}ms {{motion.ease}};
}

#workspaces button:first-child { margin-left: 0; }
#workspaces button:last-child  { margin-right: 0; }

/* Collapse Niri's unnamed scratch workspaces to zero width. */
#workspaces button:not(#niri-workspace-engine):not(#niri-workspace-comms):not(#niri-workspace-stream):not(#niri-workspace-monitoring):not(#niri-workspace-gaming):not(#niri-workspace-coding):not(#niri-workspace-browser) {
    min-width: 0;
    padding: 0;
    margin: 0;
    border: none;
    background: transparent;
    color: transparent;
}

/* Resting identity — each workspace carries its brand hue at rest. */
#niri-workspace-engine     { color: {{color.secondary}}; }
#niri-workspace-comms      { color: {{color.mist}}; }
#niri-workspace-stream     { color: {{color.tertiary}}; }
#niri-workspace-monitoring { color: {{color.error}}; }
#niri-workspace-gaming     { color: {{color.success}}; }
#niri-workspace-coding     { color: {{color.coding}}; }
#niri-workspace-browser    { color: {{color.browser}}; }

#workspaces button:hover {
    background-color: {{color.bg_alt}};
    color: {{color.fg}};
}

#workspaces button.active {
    font-weight: bold;
    border-bottom: {{geom.border}}px solid transparent;
}
#niri-workspace-engine.active     { color: {{color.fg}}; background-color: {{color.primary}};   border-bottom-color: {{color.primary}}; }
#niri-workspace-comms.active      { color: {{color.bg}}; background-color: {{color.secondary}}; border-bottom-color: {{color.secondary}}; }
#niri-workspace-stream.active     { color: {{color.bg}}; background-color: {{color.tertiary}};  border-bottom-color: {{color.tertiary}}; }
#niri-workspace-monitoring.active { color: {{color.fg}}; background-color: {{color.error}};     border-bottom-color: {{color.error}}; }
#niri-workspace-gaming.active     { color: {{color.bg}}; background-color: {{color.success}};   border-bottom-color: {{color.success}}; }
#niri-workspace-coding.active     { color: {{color.fg}}; background-color: {{color.coding}};    border-bottom-color: {{color.coding}}; }
#niri-workspace-browser.active    { color: {{color.bg}}; background-color: {{color.browser}};   border-bottom-color: {{color.browser}}; }

#workspaces button.urgent {
    color: {{color.error}};
    border-bottom: {{geom.border}}px solid {{color.error}};
}

/* Window title — text only, no chip surface. */
#window {
    color: {{color.sand}};
    padding: 0 {{geom.gap}}px;
}

