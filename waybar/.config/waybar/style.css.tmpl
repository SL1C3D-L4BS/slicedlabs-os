/* ============================================================================
 * Motion system — signal-only. Keyframes are colour-literal (GTK3 has no CSS
 * variables); each living state pairs a breathe (opacity) with a brand glow
 * (box-shadow). No CSS transforms in GTK3, so spinners are script-driven.
 * ========================================================================== */
/* Per-state keyframes combine opacity + box-shadow in one animation (GTK3 is
   unreliable with comma-listed multi-animations and rejects comma-grouped
   keyframe selectors, so stops are written out individually). */
@keyframes pulse-build {
    0%   { opacity: 1;   box-shadow: 0 0 0 0 rgba(0,0,0,0); }
    50%  { opacity: 0.7; box-shadow: 0 0 8px 0 {{color_css.glow_build}}; }
    100% { opacity: 1;   box-shadow: 0 0 0 0 rgba(0,0,0,0); }
}
@keyframes pulse-rec {
    0%   { opacity: 1;   box-shadow: 0 0 0 0 rgba(0,0,0,0); }
    50%  { opacity: 0.6; box-shadow: 0 0 9px 0 {{color_css.glow_rec}}; }
    100% { opacity: 1;   box-shadow: 0 0 0 0 rgba(0,0,0,0); }
}
@keyframes pulse-live {
    0%   { opacity: 1;   box-shadow: 0 0 0 0 rgba(0,0,0,0); }
    50%  { opacity: 0.6; box-shadow: 0 0 10px 0 {{color_css.glow_live}}; }
    100% { opacity: 1;   box-shadow: 0 0 0 0 rgba(0,0,0,0); }
}
@keyframes glow-urgent {
    0%   { box-shadow: 0 0 0 0 rgba(0,0,0,0); }
    50%  { box-shadow: 0 0 10px 0 {{color_css.glow_urgent}}; }
    100% { box-shadow: 0 0 0 0 rgba(0,0,0,0); }
}
@keyframes tab-in {
    from { opacity: 0; }
    to   { opacity: 1; }
}

