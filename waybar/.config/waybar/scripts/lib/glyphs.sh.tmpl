#!/usr/bin/env bash
# glyphs.sh — GENERATED from system/tokens.toml [icon] via render-templates.
#
# Do NOT edit this file directly — edit tokens.toml [icon] then re-render.
# Source it in any module script to bind to the single icon vocabulary that
# also drives the CSS classes and Niri:
#
#   source "$HOME/.config/waybar/scripts/lib/glyphs.sh"
#
# Icons are then $G_OK, $G_ENGINE, $G_MIC, … and g_spin <tick> for the
# braille spinner frame.

# --- State vocabulary (mirrors .empty/.ok/.info/.alert/.critical) -----------
G_OK="{{icon.ok}}"
G_FAIL="{{icon.fail}}"
G_IDLE="{{icon.idle}}"
G_INFO="{{icon.info}}"
G_ALERT="{{icon.alert}}"
G_CRIT="{{icon.critical}}"
G_BUILD="{{icon.building}}"
G_SPINNER="{{icon.spinner}}"

# --- Tab identities ---------------------------------------------------------
G_ENGINE="{{icon.engine}}"
G_COMMS="{{icon.comms}}"
G_STREAM="{{icon.stream}}"
G_MONITORING="{{icon.monitoring}}"
G_GAMING="{{icon.gaming}}"
G_CODING="{{icon.coding}}"
G_BROWSER="{{icon.browser}}"
G_MEDIA="{{icon.media}}"
G_NET="{{icon.net}}"
G_AI="{{icon.ai}}"
G_AGENDA="{{icon.agenda}}"

# --- Shared metric glyphs ---------------------------------------------------
G_CLOCK="{{icon.clock}}"
G_CPU="{{icon.cpu}}"
G_MEM="{{icon.mem}}"
G_TEMP="{{icon.temp}}"
G_DISK="{{icon.disk}}"
G_NET_DOWN="{{icon.net_down}}"
G_NET_UP="{{icon.net_up}}"
G_MIC="{{icon.mic}}"
G_MUTE="{{icon.mute}}"
G_REC="{{icon.rec}}"
G_LIVE="{{icon.live}}"
G_GPU="{{icon.gpu}}"
G_BATTERY="{{icon.battery}}"
G_BELL="{{icon.bell}}"
G_MAIL="{{icon.mail}}"
G_VPN="{{icon.vpn}}"
G_LOCK="{{icon.lock}}"
G_GIT="{{icon.git}}"
G_POMO="{{icon.pomo}}"
G_SPEND="{{icon.spend}}"
G_PLAY="{{icon.play}}"
G_PAUSE="{{icon.pause}}"
G_SPEAKER="{{icon.speaker}}"
G_FIREWALL="{{icon.firewall}}"
G_ROUTE="{{icon.route}}"

# g_spin <tick> — emit one braille spinner frame for the given tick counter.
# Uses awk substr (UTF-8 aware under gawk) so multibyte braille is safe.
g_spin() {
    awk -v s="$G_SPINNER" -v i="${1:-0}" 'BEGIN { n = length(s); printf "%s", substr(s, (i % n) + 1, 1) }'
}
