# Never version private key material, even if a future stow package places a
# key directory under the repo. The ssh/ package intentionally tracks only
# `.ssh/config` — every key form below stays local-only.
*_ed25519
*_rsa
*_ecdsa
id_*
*.pem
*.key
known_hosts*
.env
.env.*

# OBS scene files contain xdg-desktop-portal RestoreToken and hardware serial
# numbers that get rewritten by the OBS GUI. The tracked counterpart is the
# sibling .example file; live scene lives locally and is regenerated on first
# OBS launch per host.
obs/.config/obs-studio/basic/scenes/Engine.json

# Outputs of `bin/render-templates` against `system/tokens.toml`. The .tmpl
# source is the tracked truth; rerun the renderer after any tokens change.
ghostty/.config/ghostty/config
starship/.config/starship.toml
waybar/.config/waybar/style.css
waybar/.config/waybar/config.jsonc
waybar/.config/waybar/scripts/lib/glyphs.sh
waybar/.config/waybar/scripts/lib/tabs.env
niri/.config/niri/config.kdl
zellij/.config/zellij/config.kdl
# rendered zellij layouts (sources are the .kdl.tmpl files)
zellij/.config/zellij/layouts/default.kdl
zellij/.config/zellij/layouts/bare.kdl
zellij/.config/zellij/layouts/coding.kdl
zellij/.config/zellij/layouts/research.kdl
zellij/.config/zellij/layouts/engine-dev.kdl
zellij/.config/zellij/layouts/grant.kdl
zellij/.config/zellij/layouts/agent.kdl
zellij/.config/zellij/layouts/monitor-side.kdl
zellij/.config/zellij/layouts/ci.kdl
zellij/.config/zellij/layouts/vim.kdl
zellij/.config/zellij/layouts/vm.kdl
zellij/.config/zellij/layouts/studio.kdl
mako/.config/mako/config
wofi/.config/wofi/style.css
swaylock/.config/swaylock/config
wlogout/.config/wlogout/style.css
gtk/.config/gtk-3.0/gtk.css
gtk/.config/gtk-4.0/gtk.css
MangoHud/.config/MangoHud/MangoHud.conf
nvim/.config/nvim/lua/engine/palette.lua
btop/.config/btop/themes/slicedlabs.theme
fish/.config/fish/conf.d/sl-fzf.fish
fish/.config/fish/conf.d/sl-tide.fish
# rendered CLI tool themes (sources are the .tmpl files)
lazygit/.config/lazygit/config.yml
gh-dash/.config/gh-dash/config.yml
git/.config/git/delta-theme.gitconfig
cava/.config/cava/config
cava/.config/cava/shaders/eye_of_phi.frag
spotify-player/.config/spotify-player/theme.toml
qt6ct/.config/qt6ct/colors/slicedlabs.conf
obs/.config/obs-studio/themes/SlicedLabs.ovt
fastfetch/.config/fastfetch/slicedlabs-logo.txt
vim/.vim/colors/slicedlabs.vim

# Rendered wallpapers — `bin/render-brand` substitutes tokens into
# system/wallpapers/templates/*.svg.tmpl and rasterizes to PNG. The .tmpl
# is the tracked source; the .svg + .png are byproducts.
system/wallpapers/templates/*.svg
system/wallpapers/*.png
system/wallpapers/*.jpg

# Brand-assets rendered byproducts. The .tmpl + .html are tracked sources;
# the rasterized PNGs and CSS are regenerated by render-brand / render-templates.
system/brand-assets/logo/*.svg
system/brand-assets/logo/*.png
system/brand-assets/scenes/brand.css
system/brand-assets/surface/liquid-tokens.css
system/brand-assets/thumbnails/*.svg
system/brand-assets/thumbnails/*.png

# Host-private SSH override (per-host, never committed)
ssh/.ssh/config.d/local.conf

# Backup snapshots (e.g. *.bak.pre-tab-system) — snapper snapshots are
# the rollback path of record. Never commit these.
*.bak.*
*.bak

# === 2026 polyglot stack additions ===

# Plaintext sibling of *.sops files, decrypted by render-secrets.
ai/.config/ai/keys.env

# Runtime-generated compose secrets (created on first bootstrap, mode 600).
postgres/.config/postgres/dev.password
langfuse/.config/langfuse/nextauth_secret
langfuse/.config/langfuse/salt
neo4j/.config/neo4j/auth
grafana-provisioning/.config/grafana-provisioning/admin.password

# render-keys outputs. keys.toml is the tracked SSOT; the cheatsheets (.md) and
# poster source (.typ) are tracked deliverables. keys.json is regenerated at
# bootstrap (carries a generated_at stamp) and the poster PDF/PNG are typst
# build artifacts — all regenerated by `render-keys`, never committed.
quickshell/.config/quickshell/cockpit/generated/keys.json
docs/keys/*.pdf
docs/keys/*.png

# Obsidian vault — too volatile for git. Weekly tarball snapshots also stay
# out of the repo (large, per-host).
obsidian/.config/obsidian/vaults/
snapshots/

# archiso build output — the .iso is ~1.7G; iso/build.sh regenerates it. Never commit.
iso/out/

# Python build artifacts inside slicedlabs-team.
slicedlabs-team/**/__pycache__/
slicedlabs-team/*.egg-info/
slicedlabs-team/build/
slicedlabs-team/dist/

# Python bytecode anywhere (color.py lib + render-* imports)
__pycache__/
*.pyc

# Fisher-managed (vendored) fish plugins — declared in fish_plugins, reinstalled
# by `fisher update` (bootstrap layer_J). Vendor-quarantined; only user-authored
# fish config is tracked (Charter §IV / repo-canon).
fish/.config/fish/functions/*
fish/.config/fish/completions/*
fish/.config/fish/conf.d/autopair.fish
fish/.config/fish/conf.d/fzf.fish
fish/.config/fish/conf.d/z.fish
fish/.config/fish/conf.d/_tide_init.fish
!fish/.config/fish/functions/cb.fish
!fish/.config/fish/functions/gt.fish
!fish/.config/fish/functions/slc.fish
!fish/.config/fish/functions/sl.fish
!fish/.config/fish/functions/with-rocm.fish
!fish/.config/fish/functions/with-vulkan.fish
!fish/.config/fish/functions/harden-snap.fish
!fish/.config/fish/functions/fish_greeting.fish
