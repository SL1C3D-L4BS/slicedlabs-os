<?xml version="1.0" encoding="UTF-8"?>
<!-- [ENGINE] YouTube thumbnail · 1920×1080 · tokens from system/tokens.toml
     Open in Inkscape, edit the .title-text and .subtitle-text layers,
     export to PNG via:  inkscape thumbnail.svg --export-type=png \
                                  --export-filename=thumbnail.png

     The .accent-stripe layer is a constant identity marker — keep it. -->
<svg xmlns="http://www.w3.org/2000/svg" width="1920" height="1080" viewBox="0 0 1920 1080">
  <defs>
    <linearGradient id="brand-sweep" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0"   stop-color="{{color.primary}}"/>
      <stop offset="1"   stop-color="{{color.tertiary}}"/>
    </linearGradient>
    <radialGradient id="vignette" cx="0.5" cy="0.5" r="0.85">
      <stop offset="0.5" stop-color="{{color.bg}}" stop-opacity="0"/>
      <stop offset="1"   stop-color="{{color.bg}}" stop-opacity="0.65"/>
    </radialGradient>
    <pattern id="grid" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
      <path d="M 80 0 L 0 0 0 80" fill="none"
            stroke="{{color.primary}}" stroke-opacity="0.06" stroke-width="1"/>
    </pattern>
  </defs>

  <!-- Background layers -->
  <g inkscape:label="background" inkscape:groupmode="layer">
    <rect width="100%" height="100%" fill="{{color.bg}}"/>
    <rect width="100%" height="100%" fill="url(#grid)"/>
    <rect width="100%" height="100%" fill="url(#vignette)"/>
  </g>

  <!-- Accent stripe (identity marker) — left edge, full height, primary -->
  <g inkscape:label="accent-stripe" inkscape:groupmode="layer">
    <rect x="0" y="0" width="14" height="1080" fill="url(#brand-sweep)"/>
  </g>

  <!-- [ENGINE] mark, bottom-left corner -->
  <g inkscape:label="brand-mark" inkscape:groupmode="layer"
     transform="translate(80, 980)">
    <text x="0" y="0" font-family="{{font.display}}, {{font.mono}}, monospace"
          font-size="48" font-weight="700" fill="{{color.primary}}">[ENGINE]</text>
  </g>

  <!-- Title — edit in Inkscape -->
  <g inkscape:label="title-text" inkscape:groupmode="layer">
    <text x="80" y="540" font-family="{{font.display}}, {{font.mono}}, monospace"
          font-size="140" font-weight="800" fill="{{color.fg}}">DEVLOG #N</text>
  </g>

  <!-- Subtitle — edit in Inkscape -->
  <g inkscape:label="subtitle-text" inkscape:groupmode="layer">
    <text x="80" y="660" font-family="{{font.display}}, {{font.mono}}, monospace"
          font-size="64" font-weight="500" fill="{{color.tertiary}}">topic here</text>
  </g>

  <!-- Corner accent bracket, top-right -->
  <g inkscape:label="corner-accent" inkscape:groupmode="layer"
     stroke="{{color.primary}}" stroke-width="4" fill="none" opacity="0.7">
    <path d="M 1820 60 L 1880 60 L 1880 120"/>
  </g>
</svg>
