/* [ENGINE] platform — GTK 4 / Libadwaita accent overrides
 * tokens from system/tokens.toml
 *
 * Libadwaita 1.6+ respects @define-color named-color overrides at the
 * user-CSS level (gtk-4.0/gtk.css). Same accent semantics as gtk-3.0/gtk.css
 * so a single render pass keeps both GTK majors in lockstep with the rest
 * of the workstation. */

@define-color accent_color           {{color.primary}};
@define-color accent_bg_color        {{color.primary}};
@define-color accent_fg_color        {{color.fg}};

@define-color window_bg_color        {{color.bg}};
@define-color window_fg_color        {{color.fg}};
@define-color view_bg_color          {{color.bg_alt}};
@define-color view_fg_color          {{color.fg}};
@define-color headerbar_bg_color     {{color.bg_alt}};
@define-color headerbar_fg_color     {{color.fg}};

@define-color destructive_color      {{color.error}};
@define-color destructive_bg_color   {{color.error}};
@define-color destructive_fg_color   {{color.fg}};

@define-color success_color          {{color.success}};
@define-color success_bg_color       {{color.success}};
@define-color success_fg_color       {{color.bg}};

@define-color warning_color          {{color.tertiary}};
@define-color warning_bg_color       {{color.tertiary}};
@define-color warning_fg_color       {{color.bg}};

@define-color error_color            {{color.error}};
@define-color error_bg_color         {{color.error}};
@define-color error_fg_color         {{color.fg}};

@define-color card_bg_color          {{color.bg_alt}};
@define-color card_fg_color          {{color.fg}};
@define-color popover_bg_color       {{color.bg_alt}};
@define-color popover_fg_color       {{color.fg}};

@define-color sidebar_bg_color       {{color.bg}};
@define-color sidebar_fg_color       {{color.fg}};
@define-color sidebar_backdrop_color {{color.warm_shadow}};
@define-color sidebar_border_color   {{color.inactive}};
@define-color sidebar_shade_color    {{color.warm_shadow}};

/* Liquid Retina v3 — dialog/shade/thumbnail roles + ramp selection tier */
@define-color dialog_bg_color        {{color.bg_alt}};
@define-color dialog_fg_color        {{color.fg}};
@define-color thumbnail_bg_color     {{color.bg_alt_light}};
@define-color thumbnail_fg_color     {{color.fg}};
@define-color shade_color            {{color_css.overlay_dim}};

selection { background-color: {{ramp.primary_600}}; color: {{color.fg}}; }
link, *:link { color: {{color.secondary}}; }
link:visited, *:link:visited { color: {{color.wisteria}}; }
