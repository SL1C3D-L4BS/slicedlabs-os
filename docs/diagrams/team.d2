# Render with: d2 ~/.dotfiles/docs/diagrams/team.d2 ~/.cache/team.svg
# Shows how the 13 named roles + the Mem0/Qdrant/Langfuse infrastructure fit.

direction: right
style.fill: "#1E1E1E"
style.stroke: "#5EAFC9"
style.fill-pattern: dots

operator: Operator (you) {
  shape: person
  style.fill: "#F7F6F2"
  style.font-color: "#1E1E1E"
}

claude_code: Claude Code (CLI) {
  shape: cylinder
  style.fill: "#2B2B2B"
  style.stroke: "#5EAFC9"
}

team: SlicedLabs Agent Team {
  architect:   slicedlabs_architect
  engineer_1:  slicedlabs_engineer_1 (Rust / [ENGINE])
  engineer_2:  slicedlabs_engineer_2 (Python / AI / data)
  engineer_3:  slicedlabs_engineer_3 (DevOps / obs / infra)
  engineer_4:  slicedlabs_engineer_4 (Frontend, on-demand)
  design:      slicedlabs_design_assistant
  researcher:  slicedlabs_researcher
  critic:      slicedlabs_critic
  docs:        slicedlabs_docs_writer
  pm:          slicedlabs_pm
  librarian:   slicedlabs_librarian
  accountant:  slicedlabs_accountant
  oracle:      slicedlabs_oracle
}

infra: Substrate {
  mem0:      Mem0 (memory) {
    style.fill: "#2961B1"; style.font-color: "#F7F6F2"
  }
  qdrant:    Qdrant (RAG vector store) {
    style.fill: "#64A8E5"; style.font-color: "#1E1E1E"
  }
  langfuse:  Langfuse (LLM observability) {
    style.fill: "#7C6ED6"; style.font-color: "#F7F6F2"
  }
  phoenix:   Phoenix (RAG eval) {
    style.fill: "#D9892B"; style.font-color: "#1E1E1E"
  }
  n8n:       n8n (automation) {
    style.fill: "#C7D42B"; style.font-color: "#1E1E1E"
  }
  ollama:    Ollama + llama.cpp (local LLM)
  anthropic: Anthropic API (Claude)
}

operator -> claude_code: types
claude_code -> team.architect: @slicedlabs_architect
team -> infra.mem0: read/write memories
team -> infra.qdrant: hybrid search
team -> infra.anthropic: cloud inference
team -> infra.ollama: local inference (Vulkan)
team -> infra.langfuse: trace every call
team.pm -> infra.n8n: schedules
team.oracle -> infra.mem0: dedupe + archive
team.accountant -> infra.langfuse: read spend
infra.phoenix -> team.critic: regression alerts
